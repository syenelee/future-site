---
const { frontmatter } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title} | 未来</title>
    <style>
      body {
        margin: 0;
        font-family: "Microsoft YaHei", sans-serif;
        background: linear-gradient(135deg, #0f172a, #111827);
        color: #e5e7eb;
        line-height: 1.9;
      }
      .container {
        max-width: 860px;
        margin: 48px auto;
        padding: 40px;
        background: rgba(17, 24, 39, 0.88);
        border-radius: 24px;
      }
      h1 {
        color: #93c5fd;
        font-size: 2.8rem;
      }
      a {
        color: #60a5fa;
      }
      p, li {
        font-size: 1.1rem;
      }
    </style>
  </head>
  <body>
    <main class="container">
      <a href="/">← 返回首页</a>
      <h1>{frontmatter.title}</h1>
      <p>{frontmatter.date}</p>
      <slot />
    </main>
  </body>
</html>